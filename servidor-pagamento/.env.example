# ═══════════════════════════════════════════════════════════════
#  AssinaFácil — Variáveis de Ambiente (Backend)
#  Copie este arquivo para .env e preencha com suas credenciais
# ═══════════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://assinafacil.vercel.app

# ── MERCADO PAGO (Pagamentos) ─────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx

# ── GMAIL (Envio de emails) ───────────────────────────────────
# Use uma senha de aplicativo (não a senha normal do Gmail)
# Gere em: https://myaccount.google.com/apppasswords
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── TWILIO (SMS) ──────────────────────────────────────────────
# Obtenha em: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE=+5511999999999

# ── Z-API (WhatsApp) ──────────────────────────────────────────
# Obtenha em: https://z-api.io
ZAPI_INSTANCE=INSTANCE_ID
ZAPI_TOKEN=TOKEN

# ── AWS (Reconhecimento Facial) ───────────────────────────────
# Opcional - para verificação de identidade avançada
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
S3_BUCKET=assinafacil-docs

# ── TSA (Carimbo do Tempo ICP-Brasil) ─────────────────────────
# Opcional - para timestamps RFC 3161
# Deixe vazio para usar DigiCert (gratuita)
TSA_URL=http://timestamp.digicert.com
TSA_USERNAME=
TSA_PASSWORD=
TSA_POLICY_OID=
TSA_TIMEOUT=15000
